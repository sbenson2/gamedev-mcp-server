{
  "name": "gamedev-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for game development knowledge, session workflows, and engine-specific guidance. Free core docs + Pro tier for full access.",
  "main": "dist/index.js",
  "bin": {
    "gamedev-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:ci": "node --import tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "gamedev",
    "game-development",
    "monogame",
    "godot",
    "ecs",
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbenson2/gamedev-mcp-server.git"
  },
  "homepage": "https://sbenson2.github.io/gamedev-mcp-server/",
  "bugs": {
    "url": "https://github.com/sbenson2/gamedev-mcp-server/issues"
  },
  "author": "sbenson2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "docs/core",
    "docs/monogame-arch",
    "docs/godot-arch",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
